# Envio de relatório por e-mail (opcional). Copie para .env.local e preencha.
# Sem estas variáveis, o botão "Enviar ao cliente" baixa o PDF para envio manual.

# Chave da API Resend — crie em https://resend.com (free tier disponível)
RESEND_API_KEY=

# Remetente verificado no Resend (ex.: "Gilberto Negreiros <contato@seudominio.com.br>").
# Sem domínio verificado, use o sandbox: "Gilberto Negreiros <onboarding@resend.dev>"
REPORT_FROM_EMAIL=
